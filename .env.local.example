# LLM — Vercel AI Gateway (no provider API keys needed on Vercel)
# On Vercel: OIDC is automatic. Locally: `vercel env pull` or set AI_GATEWAY_API_KEY.
# Model slug format: provider/model (dots for versions)
LLM_MODEL=anthropic/claude-sonnet-4.6
# AI_GATEWAY_API_KEY=   # optional; only if not using OIDC

# GitHub — the shared team skills repository everyone saves to / browses
# Create a fine-grained PAT with Contents + Pull requests write on this repo.
GITHUB_TOKEN=
GITHUB_OWNER=Peduris
GITHUB_REPO=team-skills
GITHUB_DEFAULT_BRANCH=main
GITHUB_SAVE_MODE=pr

# App
MAX_UPLOAD_MB=10
